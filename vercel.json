{
  "version": 2,
  "name": "universal-web-to-native",
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs"
    },
    "api-gateway": {
      "root": "services/api-gateway",
      "entrypoint": "src/main.ts",
      "buildCommand": "npm run build"
    }
  },
  "rewrites": [
    {
      "source": "/api/api-gateway/(.*)?",
      "destination": {
        "type": "service",
        "service": "api-gateway"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ]
}
