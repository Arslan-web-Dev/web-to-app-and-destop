{
  "version": 2,
  "name": "universal-web-to-native",
  "buildCommand": "cd apps/web && next build",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "regions": ["iad1", "sfo1", "gru1", "lhr1", "fra1", "hkg1", "sin1", "syd1"],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@supabase-url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@supabase-anon-key",
    "NEXT_PUBLIC_API_URL": "@api-url",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@stripe-publishable-key"
  },
  "functions": {
    "apps/web/src/app/api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://*.supabase.co https://api.stripe.com; frame-ancestors 'none';"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/ai/:path*",
      "destination": "https://ai-service.universalwebtonative.com/api/v1/:path*"
    },
    {
      "source": "/api/build/:path*",
      "destination": "https://build-service.universalwebtonative.com/api/v1/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-builds",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-subscriptions",
      "schedule": "0 1 * * *"
    }
  ]
}
