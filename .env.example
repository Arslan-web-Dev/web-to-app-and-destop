# ==============================================
# DATABASE
# ==============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/uwtn_db"

# ==============================================
# SUPABASE
# ==============================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ==============================================
# JWT
# ==============================================
JWT_SECRET="super-secret-jwt-key-change-in-production-32chars"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production-32"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ==============================================
# OAUTH
# ==============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ==============================================
# STRIPE
# ==============================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# ==============================================
# REDIS
# ==============================================
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ==============================================
# AI SERVICES
# ==============================================
OPENAI_API_KEY="sk-your-openai-api-key"
GEMINI_API_KEY="your-gemini-api-key"
CLAUDE_API_KEY="your-claude-api-key"

# ==============================================
# STORAGE
# ==============================================
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="universal-web-to-native-artifacts"

# ==============================================
# EMAIL
# ==============================================
RESEND_API_KEY="re_your-resend-api-key"

# ==============================================
# URLS
# ==============================================
FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
AI_SERVICE_URL="http://localhost:8000"

# ==============================================
# APP CONFIG
# ==============================================
NODE_ENV="development"
PORT="4000"
DEBUG="true"
