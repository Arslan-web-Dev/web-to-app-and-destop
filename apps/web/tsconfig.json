{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["hooks/*"]
    },
    "allowJs": true,
    "jsx": "preserve",
    "moduleResolution": "node",
    "noEmit": true,
    "strict": true,
    "target": "es2020",
    "module": "esnext",
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
